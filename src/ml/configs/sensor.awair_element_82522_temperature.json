{
    "target": "sensor.awair_element_82522_temperature",
    "features": [
        "sensor.awair_element_82522_temperature",
        "sensor.outdoor_temperature",
        "sensor.outdoor_brightness_lux",

        "cover.rita_window_e_e_window",
